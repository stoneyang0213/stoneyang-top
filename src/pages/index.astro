---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    class="landing-layout flex-1"
  >
    <!-- ========== HERO ========== -->
    <section
      id="hero"
      class="grid gap-16 pt-16 pb-20 sm:grid-cols-[1.3fr_1fr] sm:items-center sm:pt-24 sm:pb-28"
    >
      <div>
        <div
          class="mb-7 inline-flex items-center gap-2.5 rounded-full border-[1.5px] border-accent bg-accent/5 px-5 py-2.5 text-[14px] font-bold tracking-[0.22em] text-accent uppercase font-mono-en"
        >
          <span class="block h-2 w-2 rounded-full bg-accent"></span>
          Solo · AI · Meta Validation
        </div>
        <h1
          class="font-display text-5xl leading-[1.02] font-black tracking-[-0.025em] sm:text-7xl"
        >
          超级个体 <span class="text-accent font-mono-en font-bold">OS</span>
        </h1>
        <p class="mt-5 text-xl font-medium font-display sm:text-2xl">
          stone杨 · 零到一验证手记
        </p>
        <p
          class="mt-6 max-w-2xl text-base leading-[1.7] text-muted sm:text-lg"
        >
          一个人 × 一群 Agent,用 meta 思维重造一人公司。<br />
          不做 AI 教育专家,做"普通人 + AI 追上专家"的 demo。
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a
            href="/products"
            class="inline-flex items-center gap-1.5 rounded-md bg-foreground px-6 py-3.5 font-medium text-background transition hover:bg-accent"
          >
            看我的产品矩阵 →
          </a>
          <a
            href="#find-me"
            class="inline-flex items-center gap-1.5 rounded-md border border-foreground px-6 py-3.5 font-medium text-foreground transition hover:bg-foreground hover:text-background"
          >
            加我微信聊聊
          </a>
        </div>
      </div>

      <!-- Radial Diagram -->
      <div class="relative mx-auto aspect-square w-full max-w-[420px]">
        <div
          class="absolute inset-[12%] rounded-full border-[1.5px] border-dashed border-accent/35"
        ></div>
        <div
          class="absolute inset-[32%] rounded-full border border-accent/15"
        ></div>
        <div
          class="absolute top-1/2 left-1/2 z-10 flex h-24 w-24 -translate-x-1/2 -translate-y-1/2 flex-col items-center justify-center rounded-full bg-foreground text-[13px] leading-snug font-bold text-background font-display"
        >
          <span
            class="mb-1 rounded bg-background px-1.5 py-0.5 text-[10px] font-mono-en font-semibold tracking-[0.15em] text-accent"
            >YOU</span
          >
          一人公司
        </div>
        <!-- 5 nodes -->
        <div
          class="chamber-node absolute top-[-6%] left-1/2 -translate-x-1/2"
        >
          <span class="node-n">00</span>Kernel
        </div>
        <div class="chamber-node absolute top-[28%] right-[-8%]">
          <span class="node-n">01</span>Sensors
        </div>
        <div class="chamber-node absolute right-[-4%] bottom-[18%]">
          <span class="node-n">02</span>Brain
        </div>
        <div class="chamber-node absolute bottom-[18%] left-[-4%]">
          <span class="node-n">03</span>Actuators
        </div>
        <div class="chamber-node absolute top-[28%] left-[-8%]">
          <span class="node-n">04</span>Memory
        </div>
      </div>
    </section>

    <!-- ========== EVIDENCE ========== -->
    <section
      id="evidence"
      class="border-t border-b py-20"
      style="border-color: var(--color-border)"
    >
      <div class="section-kicker">已交付的证据 · 不是营销话术</div>
      <h2 class="section-h2">用产出说话</h2>
      <div class="grid gap-10 pt-4 sm:grid-cols-3 sm:gap-12">
        <div>
          <div class="evidence-num">14<small>本</small></div>
          <div class="evidence-title">专业阅读教学论 Wiki</div>
          <p class="evidence-label">
            从 Adler(1972)→ Foster(2003)→ 王荣生(2012)三代师承<br />
            MIT 48 小时法 × Karpathy LLM Wiki 合体<br />
            7 天 demo · 三平台已发布
          </p>
        </div>
        <div>
          <div class="evidence-num">40<small>课时</small></div>
          <div class="evidence-title">AI 阅读系列课 · 第一期</div>
          <p class="evidence-label">
            10 本书 × 4 课时 · AI 流水线产出<br />
            小王子 / 夏洛的网 / 草房子 / 杀死一只知更鸟 ……<br />
            AI 索道设计原则 · 索道放山腰,陡峰留腿
          </p>
        </div>
        <div>
          <div class="evidence-num">2.0</div>
          <div class="evidence-title">Agent OS 自用中</div>
          <p class="evidence-label">
            5 大舱室 × 华为 BLM / IPD / IPMS 方法论<br />
            多业务线隔离 · 个人层不变 · 业务层独立<br />
            30+ 天实战验证 · 撬动多个 meta demo 产出
          </p>
        </div>
      </div>
    </section>

    <!-- ========== CHAMBERS ========== -->
    <section id="chambers" class="py-24">
      <div class="section-kicker">System Architecture</div>
      <h2 class="section-h2">Agent OS · 5 大舱室</h2>
      <p
        class="-mt-8 mb-12 max-w-[700px] text-base leading-[1.75] text-muted"
      >
        一人公司的操作系统。按 <strong class="text-foreground"
          >输入 → 处理 → 输出</strong
        > 把碎片精力重新组织,每个舱室只专注一件事。方法论来源:华为 BLM(业务领先)+
        IPD(集成产品开发)+ IPMS(集成营销)。
      </p>
      <div class="chambers-grid">
        <div class="chamber">
          <div class="chamber-bignum">00</div>
          <div class="chamber-cat">Kernel · 系统内核</div>
          <h3 class="chamber-h3">大脑中枢</h3>
          <div class="chamber-modules">.agents · 技能目录 · 身份认知</div>
          <div class="chamber-sep"></div>
          <p class="chamber-desc">
            配置文件。工作流模板 / skill 清单 / 边界规则,所有舱室的规范都在这里注入。
          </p>
        </div>
        <div class="chamber">
          <div class="chamber-bignum">01</div>
          <div class="chamber-cat">Sensors · 感知输入</div>
          <h3 class="chamber-h3">信息接收器</h3>
          <div class="chamber-modules">Inbox · 市场雷达 · 灵感冷藏</div>
          <div class="chamber-sep"></div>
          <p class="chamber-desc">
            OpenClaw 定时推送、日常碎片采集、偏题灵感的冷宫 — 所有外部信号的第一落点。
          </p>
        </div>
        <div class="chamber">
          <div class="chamber-bignum">02</div>
          <div class="chamber-cat">Brain · 决策中枢</div>
          <h3 class="chamber-h3">规划大脑</h3>
          <div class="chamber-modules">战略底座 · 业务规划 · 产品矩阵</div>
          <div class="chamber-sep"></div>
          <p class="chamber-desc">
            对应华为 BLM / DSTE。年度 / 季度 / 每周的战略方向 在这里成型、打磨、落章。
          </p>
        </div>
        <div class="chamber chamber-wide-1">
          <div class="chamber-bignum">03</div>
          <div class="chamber-cat">Actuators · 研发引擎</div>
          <h3 class="chamber-h3">主力产能位</h3>
          <div class="chamber-modules">IPD 产品研发 · 技能源码库</div>
          <div class="chamber-sep"></div>
          <p class="chamber-desc">
            Antigravity / Claude Code 在这里写代码、拆教案、跑 AI 流水线。产能最密集的车间。
          </p>
        </div>
        <div class="chamber chamber-wide-2">
          <div class="chamber-bignum">04</div>
          <div class="chamber-cat">Memory · 交付输出</div>
          <h3 class="chamber-h3">变现资产</h3>
          <div class="chamber-modules">IPMS 营销 · 最终产品</div>
          <div class="chamber-sep"></div>
          <p class="chamber-desc">
            HTML / PPT / 教案 / 公众号文章 — 所有"能换钱 / 能影响人"的产出 在这里打包发出。
          </p>
        </div>
      </div>
    </section>

    <!-- ========== PRODUCTS ========== -->
    <section
      id="products"
      class="border-t py-24"
      style="border-color: var(--color-border)"
    >
      <div class="section-kicker">正在做 · In Progress</div>
      <h2 class="section-h2">两个产品,一套 meta 方法论</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        <!-- Agent OS -->
        <a
          href="/products/agent-os"
          class="product-card product-dark group"
        >
          <div class="product-shape-dark"></div>
          <div>
            <div class="product-cat">Product · 一人公司 OS</div>
            <h3 class="product-h3">Agent OS</h3>
            <p class="product-desc">
              5 大舱室 × 华为 BLM / IPD / IPMS 方法论,把一人公司的碎片精力重新组织。我自己每天在用。
            </p>
          </div>
          <span class="product-more">了解详情与早鸟名单 →</span>
        </a>

        <!-- AI Reading -->
        <a
          href="/products/ai-reading"
          class="product-card product-light group"
        >
          <div class="product-shape-light"></div>
          <div>
            <div class="product-cat">Product · 12+ 岁 AI 阅读课</div>
            <h3 class="product-h3">AI 阅读系列课</h3>
            <p class="product-desc">
              AI 阅读流水线产出 <strong>40 课时</strong> 经典书籍 · 10 本 × 4 课时。接过 Adler(1972)→ Foster(2003)三代师承,招募第一期学员。
            </p>
          </div>
          <span class="product-more">了解课程与试听 →</span>
        </a>
      </div>
      <div class="mt-8 text-sm text-muted">
        还有非变现类 demo / 开源作品 →
        <a
          href="/projects"
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          >看项目页</a
        >
      </div>
    </section>

    <!-- ========== FIND ME ========== -->
    <section
      id="find-me"
      class="border-t py-24"
      style="border-color: var(--color-border)"
    >
      <div class="section-kicker">Find Me · 找我</div>
      <h2 class="section-h2">三个平台 · 同名 stone杨</h2>
      <p class="-mt-8 mb-10 text-muted">
        公众号 / 小红书 主发内容,个人微信承接产品咨询 · 扫码关注 / 加好友
      </p>
      <div class="grid gap-5 sm:grid-cols-3">
        <div class="qr-card">
          <img
            src="/qr-wechat.png"
            alt="stone杨 的个人微信二维码"
            width="600"
            height="600"
            class="aspect-square w-full rounded object-contain"
            loading="lazy"
          />
          <div class="qr-plat-en">Personal WeChat</div>
          <div class="qr-plat">个人微信</div>
          <div class="qr-desc">产品合作 · 早鸟名单 · 1:1 交流</div>
        </div>
        <div class="qr-card">
          <img
            src="/qr-gongzhonghao.png"
            alt="stone杨 的公众号二维码"
            width="600"
            height="600"
            class="aspect-square w-full rounded object-contain"
            loading="lazy"
          />
          <div class="qr-plat-en">WeChat Channel</div>
          <div class="qr-plat">公众号</div>
          <div class="qr-desc">长文 · 深度思考 · 方法论</div>
        </div>
        <div class="qr-card">
          <img
            src="/qr-xiaohongshu.png"
            alt="stone杨 的小红书二维码"
            width="600"
            height="600"
            class="aspect-square w-full rounded object-contain"
            loading="lazy"
          />
          <div class="qr-plat-en">Xiaohongshu</div>
          <div class="qr-plat">小红书</div>
          <div class="qr-desc">短内容 · 灵感碎片 · 日常</div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* === Hero Radial Diagram Nodes === */
  .chamber-node {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: var(--color-background);
    border: 1.5px solid var(--color-foreground);
    border-radius: 9999px;
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
    color: var(--color-foreground);
    font-family: var(--font-mono);
  }
  .node-n {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 10px;
  }

  /* === Section Kicker & H2 === */
  :global(.section-kicker) {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.28em;
    color: var(--color-accent);
    text-transform: uppercase;
    margin-bottom: 20px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  :global(.section-kicker)::before {
    content: "";
    width: 32px;
    height: 2px;
    background: var(--color-accent);
  }
  :global(.section-h2) {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.1;
    margin-bottom: 56px;
    letter-spacing: -0.02em;
    max-width: 900px;
    color: var(--color-foreground);
  }

  /* === Evidence === */
  :global(.evidence-num) {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(56px, 7vw, 96px);
    color: var(--color-foreground);
    line-height: 1;
    letter-spacing: -0.04em;
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 12px;
    margin-bottom: 16px;
  }
  :global(.evidence-num) small {
    font-size: 0.35em;
    opacity: 0.6;
    margin-left: 6px;
    font-weight: 500;
    font-family: var(--font-app);
  }
  :global(.evidence-title) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 19px;
    color: var(--color-foreground);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }
  :global(.evidence-label) {
    color: var(--color-muted);
    font-size: 13.5px;
    line-height: 1.75;
  }

  /* === Chambers === */
  .chambers-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 20px;
  }
  .chamber {
    grid-column: span 2;
    padding: 32px 28px;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.6);
    position: relative;
    transition: all 0.25s;
    overflow: hidden;
  }
  :global(html[data-theme="dark"]) .chamber {
    background: rgba(255, 255, 255, 0.02);
  }
  .chamber-wide-1 {
    grid-column: 2 / span 2;
  }
  .chamber-wide-2 {
    grid-column: 4 / span 2;
  }
  .chamber:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  .chamber-bignum {
    position: absolute;
    top: 20px;
    right: 24px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 56px;
    color: var(--color-accent);
    opacity: 0.12;
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .chamber-cat {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--color-accent);
    text-transform: uppercase;
    margin-bottom: 10px;
    font-weight: 700;
  }
  .chamber-h3 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 22px;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
  }
  .chamber-modules {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-foreground);
    font-weight: 500;
    margin-bottom: 14px;
    letter-spacing: 0.02em;
    opacity: 0.75;
  }
  .chamber-sep {
    width: 32px;
    height: 1px;
    background: var(--color-accent);
    margin-bottom: 14px;
  }
  .chamber-desc {
    color: var(--color-muted);
    font-size: 13.5px;
    line-height: 1.75;
  }

  /* === Products === */
  .product-card {
    padding: 48px 40px 44px;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 300px;
    transition: transform 0.25s;
  }
  .product-card:hover {
    transform: translateY(-4px);
  }
  .product-dark {
    background: var(--color-foreground);
    color: var(--color-background);
  }
  .product-light {
    background: var(--color-background);
    color: var(--color-foreground);
    border: 1px solid var(--color-foreground);
  }
  .product-shape-dark {
    position: absolute;
    right: -30px;
    bottom: -30px;
    width: 180px;
    height: 180px;
    border: 2px solid var(--color-background);
    border-radius: 50%;
    opacity: 0.08;
    pointer-events: none;
  }
  .product-shape-light {
    position: absolute;
    right: -60px;
    bottom: -60px;
    width: 180px;
    height: 180px;
    border: 2px solid var(--color-foreground);
    transform: rotate(45deg);
    opacity: 0.08;
    pointer-events: none;
  }
  .product-cat {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 16px;
    opacity: 0.6;
    font-weight: 600;
  }
  .product-h3 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 38px;
    margin-bottom: 16px;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }
  .product-desc {
    font-size: 15px;
    opacity: 0.85;
    margin-bottom: 32px;
    line-height: 1.7;
  }
  .product-desc :global(strong) {
    font-weight: 700;
    opacity: 1;
  }
  .product-more {
    font-size: 14px;
    font-weight: 500;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    align-self: flex-start;
  }

  /* === QR Cards === */
  :global(.qr-card) {
    padding: 24px 20px 28px;
    border: 1px solid var(--color-border);
    background: var(--color-background);
    text-align: center;
    transition: border-color 0.2s;
  }
  :global(.qr-card:hover) {
    border-color: var(--color-foreground);
  }
  :global(.qr-plat-en) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--color-accent);
    text-transform: uppercase;
    margin-top: 18px;
    margin-bottom: 6px;
    font-weight: 600;
  }
  :global(.qr-plat) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    margin-bottom: 4px;
    color: var(--color-foreground);
  }
  :global(.qr-desc) {
    color: var(--color-muted);
    font-size: 13px;
  }

  /* === Mobile === */
  @media (max-width: 768px) {
    .chambers-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .chamber,
    .chamber-wide-1,
    .chamber-wide-2 {
      grid-column: 1;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (
      document.querySelector("#main-content") as HTMLElement
    )?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
